{
  "compilerOptions": {
    "target": "es2020",
    "module": "CommonJS",

    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,

    "strictNullChecks": true,
    "skipLibCheck": true,

    "typeRoots": ["node_modules/@types", "../../../node_modules/@types", "../../../types/global.*.ts"]
  },
  "include": ["./**/*.ts", "../../../types/**/*.ts"]
}
